# =============================================================================
# OTel Mastery Lab — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the required values before running
# docker compose up. Never commit .env to source control.
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED: New Relic Ingest License Key
# Find this at: one.newrelic.com → (account menu) → API Keys
# Key type must be: INGEST - LICENSE
# -----------------------------------------------------------------------------
NR_LICENSE_KEY=your_license_key_here

# -----------------------------------------------------------------------------
# REQUIRED: New Relic OTLP Endpoint
# US accounts:  https://otlp.nr-data.net
# EU accounts:  https://otlp.eu01.nr-data.net
# Note: No port number — both endpoints use HTTPS/443 by default.
# -----------------------------------------------------------------------------
NR_OTLP_ENDPOINT=https://otlp.nr-data.net

# -----------------------------------------------------------------------------
# Load Generator Rate
# Requests per second sent by the load-generator container to order-service.
# Default: 10 rps
# Reduce to 2-3 on low-spec machines; increase to 50 for cardinality exercises.
# -----------------------------------------------------------------------------
LOAD_RATE=10

# -----------------------------------------------------------------------------
# Application Log Level
# Controls log verbosity for both order-service and payment-service.
# Valid values: DEBUG, INFO, WARN, ERROR
# Default: INFO
# Use DEBUG to see trace context injected into logs (Module 7).
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Simulate Error Responses
# When true, order-service randomly returns HTTP 500 on ~10% of requests.
# Used in Module 12 incident response exercises.
# Valid values: true, false
# Default: false
# -----------------------------------------------------------------------------
SIMULATE_ERRORS=false

# -----------------------------------------------------------------------------
# Simulate Slow Payment Processing
# When true, payment-service adds a random delay of 200-2000ms per request.
# Used in Module 9 tail sampling and Module 12 latency exercises.
# Valid values: true, false
# Default: false
# -----------------------------------------------------------------------------
SIMULATE_SLOW=false

# -----------------------------------------------------------------------------
# Payment Failure Rate
# Fraction of payments that payment-service randomly declines (HTTP 402). The
# error cascades: order-service marks its span errored and returns HTTP 402
# "Payment declined" (a payment error, not a gateway error), so the whole
# distributed trace shows the failure in New Relic.
# Default: 0.02 (1 in 50 orders). Set to 0 for all-success runs (clean L101
# M3/M4 data); raise (e.g. 0.2) for a heavier error-rate demo.
# -----------------------------------------------------------------------------
PAYMENT_ERROR_RATE=0.02

# -----------------------------------------------------------------------------
# Collector Config File
# Filename (relative to the configs/ directory) to mount into otelcol-agent.
# Change this value and run: docker compose up -d otelcol-agent
# to hot-swap configs without restarting the full stack.
#
# Available configs (files that actually exist in configs/):
#   collector-agent.yaml          — Standard L101/L201 config (default). Handles
#                                    traces, metrics, AND logs (the apps export logs
#                                    over OTLP), and redacts PII from logs (Module 7).
#   collector-agent-exercise.yaml — Module 6 starter skeleton (build-it-up exercise).
#   collector-selfmon.yaml        — Module 8 self-monitoring (fast self-metrics scrape).
#   collector-cardinality.yaml    — Module 11 cardinality control (drops high-card attrs).
#   collector-gateway.yaml        — Two-tier gateway / tail sampling (Module 9). Mounted
#                                    into the otelcol-gateway service, which is opt-in:
#                                    run  docker compose --profile gateway up -d
#   collector-broken-1.yaml       — Broken: wrong processor order (M12 Ex 2A)
#   collector-broken-2.yaml       — Broken: invalid API key (M12 Ex 2B)
#   collector-broken-3.yaml       — Broken: tail sampling too low (M12 Ex 2C)
# -----------------------------------------------------------------------------
COLLECTOR_CONFIG=collector-agent.yaml
